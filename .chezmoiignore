# .chezmoiignore — target paths chezmoi must NEVER manage.
#
# This is a PUBLIC dotfiles repo. Secrets and machine-specific state must stay
# out. Files are added individually, so this is primarily a guardrail against an
# accidental recursive `chezmoi add`/`re-add` sweeping sensitive paths in.

# Self
.config/chezmoi

# Plexus Bootstrap. See https://github.com/plexus-ms/bootstrap.
bootstrap/

# User data
Desktop/
Development/
Documents/
Downloads/
Library/
Movies/
Music/
Pictures/
Public/
remnote/
OneDrive*

# Application data
Applications/
.spss

# macOS
.CFUserTextEncoding
.Trash/
**/.DS_Store

# Trust
.gnupg
.ssh/*
!.ssh/config
!.ssh/allowed_signers
# contains secrets
